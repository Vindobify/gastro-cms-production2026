// Prisma Schema for Gastro CRM
// Shared Database with gastro-cms-multi
// This schema extends the existing models from gastro-cms-multi

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------
// CORE TENANCY (Extended with Stripe fields)
// ------------------------------------------

model Tenant {
  id              String   @id @default(cuid())
  
  // Identifikation
  name            String
  domain          String?  @unique
  subdomain       String?  @unique
  
  // Status & Plan
  isActive        Boolean  @default(true)
  plan            String   @default("STANDARD")
  
  // Inhaber-Kontakt
  ownerName       String?
  email           String
  phone           String?
  
  // Stripe Connect Fields (NEW)
  stripeAccountId        String?
  stripeOnboardingStatus String?  // pending, completed, failed
  stripeOnboardingUrl    String?
  stripeConnectedAt      DateTime?
  commissionRate         Decimal   @default(0.10) // 10%
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  payments        Payment[]
  settings        RestaurantSettings?
  orders          Order[]
  
  @@map("tenants")
}

// ------------------------------------------
// PAYMENT MODEL (NEW)
// ------------------------------------------

model Payment {
  id              Int      @id @default(autoincrement())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId         Int      @unique
  order           Order    @relation("OrderPayment", fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod   String   // CASH, CARD, STRIPE, BANKOMAT
  amount          Decimal
  commission      Decimal  // 10% des Betrags
  commissionPaid  Boolean  @default(false)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([tenantId])
  @@index([orderId])
  @@map("payments")
}

// ------------------------------------------
// ORDER MODEL (Extended with payment fields)
// ------------------------------------------

model Order {
  id            Int         @id @default(autoincrement())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNumber   String
  customerId    Int
  totalAmount   Decimal
  deliveryType  String      @default("PICKUP")
  deliveryTime  DateTime?
  status        String      @default("PENDING")
  notes         String?
  
  // Payment fields (NEW)
  paymentId     Int?
  payment       Payment?    @relation("OrderPayment")
  paymentMethod String?     // CASH, CARD, STRIPE, BANKOMAT
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@unique([orderNumber, tenantId])
  @@index([tenantId])
  @@map("orders")
}

// ------------------------------------------
// RESTAURANT SETTINGS (Reference)
// ------------------------------------------

model RestaurantSettings {
  id                    Int      @id @default(autoincrement())
  tenantId              String   @unique
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  restaurantName        String
  address               String?
  city                  String?
  postalCode            String?
  phone                 String?
  email                 String?
  coverImage            String?  @map("cover_image")  // Restaurant-Card-Bild für Landing Page
  category              String?  // Restaurant-Kategorie (z.B. "Italienisch", "Asiatisch")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("restaurant_settings")
}

// ------------------------------------------
// CONTACT REQUESTS (NEW)
// ------------------------------------------

model ContactRequest {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  phone       String?
  message     String
  status      String   @default("NEW") // NEW, IN_PROGRESS, RESOLVED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("contact_requests")
}

// ------------------------------------------
// ORDER REQUESTS (NEW)
// ------------------------------------------

model OrderRequest {
  id                  Int      @id @default(autoincrement())
  // Geschäftsinformationen
  businessType        String
  restaurantName      String
  ownerName           String
  email               String
  phone               String
  address             String
  postalCode          String
  city                String
  
  // Lieferservice Informationen
  hasDeliveryService  Boolean
  deliveryServiceName String?
  monthlyRevenue      Decimal?
  deliveryPercentage  Decimal? // Prozentsatz des Kunden
  calculatedSavings  Decimal? // Berechnete Ersparnis
  
  // Domain Informationen
  hasDomain           Boolean
  existingDomain      String?
  desiredDomain       String?
  
  // Rechtliches
  acceptedTerms       Boolean
  acceptedPrivacy     Boolean
  acceptedAV          Boolean
  
  // Status & Payment
  status              String   @default("PENDING") // PENDING, PAID, CONVERTED, CANCELLED
  paymentAmount       Decimal  @default(0)
  stripeSessionId    String?
  convertedToTenantId String?  // Referenz zum Tenant, wenn umgewandelt
  
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@map("order_requests")
}

// ------------------------------------------
// APPOINTMENTS (NEW)
// ------------------------------------------

model Appointment {
  id              Int      @id @default(autoincrement())
  businessType    String
  restaurantName  String
  firstName       String
  lastName        String
  email           String
  phone           String
  appointmentType String   // "online" oder "lokal"
  date            DateTime
  time            String
  address         String?
  postalCode      String?
  city            String?
  message         String?
  status          String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("appointments")
}
